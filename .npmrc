# Linked @base/* packages carry their own node_modules; hoist three so one copy is used
# (prevents “Multiple instances of Three.js” and Object3D.add / instanceof bugs).
public-hoist-pattern[]=*three*

# Windows: fewer symlinks / in-place updates → avoids EPERM unlink on esbuild.exe during install.
# If install still fails, close every Vite/Node terminal, delete node_modules, run pnpm install again.
node-linker=hoisted
package-import-method=copy
